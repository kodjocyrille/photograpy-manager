{
  "name": "photoagence-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "PHOTOAGENCE — Tailwind CSS build",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/main/resources/static/css/input.css -o ./src/main/resources/static/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/main/resources/static/css/input.css -o ./src/main/resources/static/css/output.css --watch",
    "dev": "npm run watch:css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
